{
  "entities": {
    "Goal": {
      "title": "Goal",
      "description": "A user goal with tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["professional", "personal", "financial", "health"] },
        "targetDate": { "type": "string" },
        "time": { "type": "string" },
        "color": { "type": "string" },
        "progress": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed", "on-hold"] },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "completed": { "type": "boolean" },
              "date": { "type": "string" },
              "time": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "title", "category", "targetDate", "status", "tasks"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "A calendar event or appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "color": { "type": "string" },
        "goalId": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["id", "title", "start", "end", "category", "color"]
    },
    "DayAchievement": {
      "title": "DayAchievement",
      "description": "A daily achievement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "type": { "type": "string", "enum": ["manual", "habit"] }
      },
      "required": ["id", "date", "content", "createdAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit to track",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["personal", "professional"] },
        "completedDates": { "type": "array", "items": { "type": "string" } },
        "acquired": { "type": "boolean" },
        "streak": { "type": "number" }
      },
      "required": ["id", "title", "category", "completedDates", "acquired", "streak"]
    },
    "Note": {
      "title": "Note",
      "description": "A text or voice note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "audioUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "voice"] }
      },
      "required": ["id", "content", "createdAt", "type"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User specific application settings",
      "type": "object",
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "color": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "theme": { "type": "string", "enum": ["dark", "light"] },
        "defaultTab": { "type": "string" },
        "showHolidays": { "type": "boolean" },
        "selectedCountry": { "type": "string" },
        "selectedRegion": { "type": "string" },
        "workEndNotify": { "type": "boolean" },
        "workEndTime": { "type": "string" },
        "workEndDays": { "type": "array", "items": { "type": "number" } }
      }
    },
    "GoogleAccount": {
      "title": "GoogleAccount",
      "description": "A connected Google account for calendar sync",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "expiryDate": { "type": "number" }
      },
      "required": ["id", "email", "accessToken", "refreshToken", "expiryDate"]
    }
  },
  "firestore": {
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User goals"
    },
    "/users/{userId}/events/{eventId}": {
      "schema": "CalendarEvent",
      "description": "User calendar events"
    },
    "/users/{userId}/achievements/{achievementId}": {
      "schema": "DayAchievement",
      "description": "User daily achievements"
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "User habits"
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes"
    },
    "/users/{userId}/settings/current": {
      "schema": "UserSettings",
      "description": "User settings"
    },
    "/users/{userId}/googleAccounts/{accountId}": {
      "schema": "GoogleAccount",
      "description": "User connected Google accounts"
    }
  }
}
